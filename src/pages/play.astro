---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/data/siteConfig";

const playSteps = [
  ["1", "Pick", "Select the bottle with the top color you want to move."],
  ["2", "Pour", "Move it into an empty bottle or onto the same top color."],
  ["3", "Clear", "Finish each filled bottle as one clean color."],
];

const tips = [
  "Save empty bottles for real problems.",
  "Check the second layer before you pour.",
  "Restart early when every route is blocked.",
];
---

<BaseLayout
  title={`Play ${siteConfig.name} Online`}
  description={`Play ${siteConfig.name} online free in your browser. Sort mixed liquid colors into matching bottles on desktop or mobile.`}
>
  <section class="play-stage" id="top">
    <div class="play-stage-bg" aria-hidden="true"></div>
    <div class="play-shell" data-game-shell>
      <iframe src="/game/index.html" title="Magic Sort game" allow="autoplay; fullscreen *" allowfullscreen></iframe>
      <div class="play-float-controls">
        <button type="button" data-share-game aria-label="Share game">
          <span>Share</span>
        </button>
        <button type="button" data-fullscreen-game aria-label="Fullscreen game">
          <span>Fullscreen</span>
        </button>
      </div>
    </div>
  </section>

  <section class="play-info-section">
    <div class="play-info-head">
      <p class="eyebrow">Play online</p>
      <h1>Magic Sort in your browser.</h1>
      <p>Free, instant, and built for quick color sorting sessions.</p>
    </div>
    <div class="play-step-grid">
      {playSteps.map(([number, title, text]) => (
        <article>
          <span>{number}</span>
          <strong>{title}</strong>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="play-info-section play-split-section">
    <div>
      <p class="eyebrow">Level flow</p>
      <p class="play-panel-title">Sort colors with calm planning.</p>
      <div class="play-category-pills">
        <a href="/strategy/">Strategy</a>
        <a href="/difficulty-guide/">Difficulty</a>
        <a href="/game-mechanics/">Mechanics</a>
      </div>
    </div>
    <div class="play-tip-panel">
      <p class="eyebrow">Tips</p>
      <ul>
        {tips.map((tip) => <li>{tip}</li>)}
      </ul>
    </div>
  </section>

  <section class="play-info-section seo-copy-section" aria-labelledby="play-page-guide">
    <div class="section-head">
      <h2 id="play-page-guide">Play guide.</h2>
    </div>
    <div class="seo-copy-grid">
      <article class="seo-copy-card seo-copy-wide">
        <h3>What makes Magic Sort different</h3>
        <p>Magic Sort keeps the rules simple and makes the planning visible. Every bottle shows its top layer, but the hidden colors underneath decide whether a move opens the board or creates a trap. The best sessions feel calm because every good pour makes the layout easier to understand.</p>
      </article>
      <article class="seo-copy-card">
        <h3>How to start a strong solve</h3>
        <p>Look for top colors that can join cleanly, then decide which empty bottle you need to protect. A move is strongest when it completes a color, exposes a needed layer, or creates more space for future pours.</p>
      </article>
      <article class="seo-copy-card">
        <h3>Best sessions</h3>
        <p>Play an easier level when you want a short break, then move into tighter layouts when you want deeper focus. The browser game works without an account, so it is suitable for quick desktop sessions, tablet play, or mobile puzzle breaks.</p>
      </article>
    </div>
  </section>
  <script is:inline>
    (() => {
      const shell = document.querySelector("[data-game-shell]");
      const iframe = shell?.querySelector("iframe");
      const fullscreen = document.querySelector("[data-fullscreen-game]");
      const share = document.querySelector("[data-share-game]");
      fullscreen?.addEventListener("click", async () => {
        const active = document.fullscreenElement;
        if (active) {
          await document.exitFullscreen?.();
          return;
        }
        await (iframe?.requestFullscreen?.() ?? shell?.requestFullscreen?.());
      });
      share?.addEventListener("click", async () => {
        const data = { title: "Magic Sort", text: "Play Magic Sort online.", url: location.href };
        try {
          if (navigator.share) await navigator.share(data);
          else await navigator.clipboard?.writeText(location.href);
        } catch {}
      });
    })();
  </script>
</BaseLayout>
