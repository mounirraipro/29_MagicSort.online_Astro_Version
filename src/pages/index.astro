---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { articles } from "@/data/articles";
import { externalGames } from "@/data/externalGames";
import { siteConfig } from "@/data/siteConfig";
import { brandAccentClass } from "@/data/accentClasses";
import { GAME_ASSET_VERSION } from "@/data/gameVersion";

const recentPosts = articles.slice(0, 3);
const totalLevels = 30;
const homeBentoGames = [
  {
    href: "/play/",
    title: "Magic Sort Online",
    shortTitle: "Magic Sort",
    category: "Now playing",
    thumbnail: "/apple-touch-icon.png",
    accentClass: brandAccentClass,
  },
  ...externalGames.map((game) => ({
    href: `/games/${game.slug}/`,
    title: game.title,
    shortTitle: game.shortTitle,
    category: game.category,
    thumbnail: game.thumbnail,
    accentClass: game.accentClass,
  })),
].slice(0, 8);
const homeBentoLeft = homeBentoGames.slice(0, 4);
const homeBentoRight = homeBentoGames.slice(4, 8);
const gameIframeSrc = `/game/index.html?v=${GAME_ASSET_VERSION}`;

const faqItems = [
  ["What is Magic Sort?", "Magic Sort is a free online bottle sorting puzzle where you pour layered colors between tubes until every filled bottle contains one clean color."],
  ["How do you play Magic Sort online?", "Choose a bottle, then pour into an empty bottle or onto the same top color when there is enough room. Keep planning until all colors are organized."],
  ["Is Magic Sort free?", "Yes. You can play Magic Sort free in the browser with no download, no account, and no app install required."],
  ["Does Magic Sort work on mobile?", "Yes. Magic Sort supports touch and mouse play, so it works on phones, tablets, laptops, and desktop browsers."],
  ["What are the Magic Sort controls?", "Click or tap one tube or bottle to select it, then click or tap a second tube to pour when the move is allowed. The same logic works with mouse and touch controls."],
  ["Do I need to download Magic Sort?", "No. Magic Sort runs directly in the browser. You can open the page, load the game, and start sorting colors without downloading an app or extension."],
  ["Can I play Magic Sort unblocked?", "Magic Sort is a browser game, so it can work anywhere your network allows game websites. If a school, office, or public network blocks games, that local network rule controls access."],
  ["Why do I get stuck in Magic Sort?", "Most stuck boards happen when every empty tube is filled too early. Keep one helper space open, uncover buried colors slowly, and restart before the board becomes fully locked."],
  ["How many levels are included?", `The current game includes ${totalLevels} browser levels with easier openings and tighter late-game layouts.`],
];

const homeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "VideoGame",
    name: "Magic Sort",
    alternateName: ["MagicSort", "Magic Sort Online", "Water Sort Puzzle", "Bottle Sort Game"],
    url: `${siteConfig.siteUrl}/`,
    image: new URL(siteConfig.defaultOgImage, siteConfig.siteUrl).href,
    description: siteConfig.description,
    applicationCategory: "Game",
    gamePlatform: ["Web browser", "Desktop", "Mobile", "Tablet"],
    genre: ["Bottle sorting puzzle", "Water sort puzzle", "Color sort puzzle", "Logic game"],
    operatingSystem: "Any modern browser",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
      availability: "https://schema.org/InStock",
    },
    publisher: {
      "@type": "Organization",
      name: siteConfig.publisherName,
      url: siteConfig.siteUrl,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map(([question, answer]) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: {
        "@type": "Answer",
        text: answer,
      },
    })),
  },
];
---

<BaseLayout title={siteConfig.name} description={siteConfig.description} structuredData={homeStructuredData}>
  <section class="hero-play">
    <div class="home-game-lobby">
      <div class="game-bento-grid game-bento-grid-side" aria-label="Games you can play">
        {homeBentoLeft.map((game, index) => (
          <a class:list={["game-bento-card", game.accentClass, { "game-bento-card-featured": index === 0 }]} href={game.href}>
            <img src={game.thumbnail} alt={`${game.title} thumbnail`} width="640" height="360" loading="lazy" />
            <div>
              <span>{game.category}</span>
              <strong>{game.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>
      <div class="hero-game">
        <iframe src={gameIframeSrc} title="Play Magic Sort" loading="eager"></iframe>
      </div>
      <div class="game-bento-grid game-bento-grid-side" aria-label="More games">
        {homeBentoRight.map((game, index) => (
          <a class:list={["game-bento-card", game.accentClass, { "game-bento-card-featured": index === 0 }]} href={game.href}>
            <img src={game.thumbnail} alt={`${game.title} thumbnail`} width="640" height="360" loading="lazy" />
            <div>
              <span>{game.category}</span>
              <strong>{game.shortTitle}</strong>
            </div>
          </a>
        ))}
      </div>
    </div>
    <div class="hero-copy">
      <div class="hero-copy-main">
        <p class="eyebrow">Instant play</p>
        <h1>Magic Sort</h1>
        <p>Play Magic Sort online for free. Pour layered colors between tubes and bottles, protect your empty space, and solve relaxing color sorting levels with no download and no account.</p>
        <a class="text-link hero-note" href="/how-to-play/">Learn the rules</a>
      </div>
      <div class="hero-play-panel">
        <div class="hero-panel-top">
          <span>Ready in browser</span>
          <strong>Start sorting colors.</strong>
        </div>
        <div class="hero-actions">
          <a class="primary-action" href="/play/"><span class="play-triangle"></span>Play Full Screen</a>
          <a class="secondary-action" href="/how-to-play/">How To Play</a>
        </div>
        <dl class="stat-row">
          <div><dt>{totalLevels}</dt><dd>Levels</dd></div>
          <div><dt>4</dt><dd>Layers</dd></div>
          <div><dt>{articles.length}</dt><dd>Guides</dd></div>
        </dl>
      </div>
    </div>
  </section>

  <section class="home-section home-search-intent">
    <div class="home-section-head split-head">
      <div>
        <p class="eyebrow">Magic Sort guide</p>
        <h2>Play Magic Sort online.</h2>
      </div>
      <p>Magic Sort turns mixed liquid colors into a calm logic challenge built around readable tubes, smart bottle space control, and satisfying clean finishes.</p>
    </div>
    <div class="process-strip">
      <article>
        <span>Free</span>
        <h3>Browser play</h3>
        <p>Open <a href="/play/">Magic Sort online</a> and start instantly. The Magic Sort game runs in the browser, so there is no app store, installer, or sign-up flow.</p>
      </article>
      <article>
        <span>Read</span>
        <h3>Layer logic</h3>
        <p>Each move starts with the top liquid color in a tube or bottle, but the hidden layers underneath decide whether the next few pours will stay flexible.</p>
      </article>
      <article>
        <span>Plan</span>
        <h3>Empty space</h3>
        <p>Empty bottles and tubes are your strongest tools. Use them to uncover colors, build clean stacks, and avoid trapping important layers.</p>
      </article>
      <article>
        <span>Finish</span>
        <h3>Clean bottles</h3>
        <p>The level is solved when each filled bottle holds one color from top to bottom. The best route is patient, not frantic.</p>
      </article>
    </div>
  </section>

  <section class="home-section seo-copy-section" aria-labelledby="magic-sort-overview">
    <div class="section-head">
      <p class="eyebrow">About the game</p>
      <h2 id="magic-sort-overview">What is Magic Sort?</h2>
      <p>Magic Sort is a free color sorting puzzle about pouring liquids between glass tubes and bottles until every color is grouped cleanly.</p>
    </div>
    <div class="seo-copy-grid">
      <article class="seo-copy-card seo-copy-wide">
        <h3>Magic Sort gameplay overview</h3>
        <p>Each Magic Sort level starts with tubes or bottles full of mixed liquid layers and a small amount of empty space. You can pour the top color into an empty bottle or onto the same color when there is room. Those simple rules create a planning puzzle where one rushed move can block the next several pours.</p>
      </article>
      <article class="seo-copy-card">
        <h3>How to play Magic Sort</h3>
        <p>Start by scanning the top colors, then choose a helper tube to keep open. Build one completed color at a time, avoid filling every spare bottle too early, and use restarts when the board becomes locked.</p>
      </article>
      <article class="seo-copy-card">
        <h3>Why play Magic Sort here?</h3>
        <p>The browser version keeps Magic Sort easy to access on desktop, tablet, and mobile. You can open a short session, play a level, and return later without installing an app or creating an account.</p>
      </article>
    </div>
  </section>

  <section class="home-section seo-copy-section" aria-labelledby="magic-sort-controls">
    <div class="section-head">
      <p class="eyebrow">Rules and controls</p>
      <h2 id="magic-sort-controls">How to play and control Magic Sort</h2>
      <p>Magic Sort is easy to start because the controls are the same on desktop and mobile: choose a source tube, then choose where the color should go.</p>
    </div>
    <div class="seo-copy-grid">
      <article class="seo-copy-card">
        <h3>Mouse controls</h3>
        <p>On desktop, click a bottle or tube to select the top liquid color. Click a second tube to pour if it is empty or if the top color matches and there is enough room.</p>
      </article>
      <article class="seo-copy-card">
        <h3>Touch controls</h3>
        <p>On phones and tablets, tap the first tube, then tap the target tube. The browser version keeps the same Magic Sort rules whether you use a mouse, trackpad, or touchscreen.</p>
      </article>
      <article class="seo-copy-card seo-copy-wide">
        <h3>Winning a Magic Sort level</h3>
        <p>The goal is to finish every filled tube as one clean color. A good move either completes a color, reveals a buried layer, or protects the empty space you need for later. If a pour only makes the board busier, wait and look for a cleaner option.</p>
      </article>
    </div>
  </section>

  <section class="home-section seo-copy-section" aria-labelledby="magic-sort-free-online">
    <div class="section-head">
      <p class="eyebrow">Free browser game</p>
      <h2 id="magic-sort-free-online">Play Magic Sort free, online, and without download</h2>
      <p>The main Magic Sort game is built for quick browser sessions, so players can open a level, solve a few tubes, and leave without installing anything.</p>
    </div>
    <div class="seo-copy-grid">
      <article class="seo-copy-card">
        <h3>Magic Sort online</h3>
        <p>The game loads in a web browser on desktop, tablet, and mobile. That makes Magic Sort useful for short breaks because there is no app store step and no account setup.</p>
      </article>
      <article class="seo-copy-card">
        <h3>Magic Sort unblocked access</h3>
        <p>If your network allows browser game sites, Magic Sort can be played directly from the page. Some schools, offices, or public networks block games, and those local rules decide access.</p>
      </article>
      <article class="seo-copy-card">
        <h3>No download required</h3>
        <p>You do not need a mod APK, installer, extension, or sign-in flow. Open Magic Sort, use the on-page game frame, and start sorting liquid colors between tubes.</p>
      </article>
    </div>
  </section>

  <section class="home-section home-process">
    <div class="home-section-head split-head">
      <div>
        <p class="eyebrow">Strategy tips</p>
        <h3>Better Magic Sort moves.</h3>
      </div>
      <p>These are the habits that stop most color sorting boards from getting stuck.</p>
    </div>
    <div class="process-strip">
      <article><span>Tip</span><h3>Keep one tube open</h3><p>Empty space is your safety valve. Do not spend every helper bottle unless the move reveals or completes a useful color.</p></article>
      <article><span>Tip</span><h3>Read hidden layers</h3><p>Look at what a pour uncovers. The best Magic Sort move often reveals the next color you need rather than simply moving the top color away.</p></article>
      <article><span>Tip</span><h3>Finish one color</h3><p>When a tube is close to complete, use matching pours to lock that color cleanly and reduce the number of mixed bottles on the board.</p></article>
      <article><span>Tip</span><h3>Restart early</h3><p>If every tube is blocked, reset before wasting time on random pours. A fresh route is faster than forcing a trapped layout.</p></article>
    </div>
  </section>

  <section class="home-section home-authority">
    <div class="authority-panel">
      <div class="home-section-head">
        <p class="eyebrow">Puzzle context</p>
        <h3>Built on classic sorting logic.</h3>
        <p>
          Keep <a class="site-identity-link" href="/"><strong>www.magicsort.online</strong></a> as your quick route back to free browser bottle sorting, then explore the puzzle and game-design ideas behind the genre.
        </p>
      </div>
      <div class="authority-links" aria-label="External puzzle references">
        <a href="https://en.wikipedia.org/wiki/Water_sort_puzzle" target="_blank" rel="noopener noreferrer">
          <span>Wikipedia</span>
          <strong>Water sort puzzle</strong>
          <small>Background on the color sorting puzzle format.</small>
        </a>
        <a href="https://en.wikipedia.org/wiki/Puzzle_video_game" target="_blank" rel="noopener noreferrer">
          <span>Wikipedia</span>
          <strong>Puzzle video games</strong>
          <small>How simple rules create deep planning challenges.</small>
        </a>
        <a href="https://www.youtube.com/results?search_query=water+sort+puzzle+strategy" target="_blank" rel="noopener noreferrer">
          <span>YouTube</span>
          <strong>Strategy videos</strong>
          <small>Watch color sorting routes and planning examples.</small>
        </a>
      </div>
    </div>
  </section>

  <section class="home-section home-process">
    <div class="home-section-head split-head">
      <div>
        <p class="eyebrow">How it works</p>
        <h3>Simple pours. Real planning.</h3>
      </div>
      <p>Four steps from mixed bottles to a clean board.</p>
    </div>
    <div class="process-strip">
      <article><span>01</span><h3>Pick</h3><p>Select a bottle with the color you want to move.</p></article>
      <article><span>02</span><h3>Match</h3><p>Pour into an empty bottle or onto the same top color.</p></article>
      <article><span>03</span><h3>Protect</h3><p>Keep enough empty space for future colors to move.</p></article>
      <article><span>04</span><h3>Clear</h3><p>Finish every bottle as a single-color stack.</p></article>
    </div>
  </section>

  <section class="home-section home-blog">
    <div class="blog-editorial">
      <div class="home-section-head">
        <p class="eyebrow">From the blog</p>
        <h3>Sharper sorting habits.</h3>
        <p>Short reads for cleaner pours, better focus, and calmer play.</p>
        <a class="text-link" href="/blog/">Browse all articles</a>
      </div>
      <div class="blog-board">
        <a class="editorial-card editorial-card-featured" href={`/blog/${recentPosts[0].slug}/`}>
          <span>{recentPosts[0].category}</span>
          <h3>{recentPosts[0].title}</h3>
          <p>{recentPosts[0].description}</p>
          <small>{recentPosts[0].readTime}</small>
        </a>
        <div class="article-rail">
          {recentPosts.slice(1).map((post) => (
            <a class="editorial-card editorial-card-row" href={`/blog/${post.slug}/`}>
              <span>{post.category}</span>
              <h3>{post.title}</h3>
              <small>{post.readTime}</small>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="home-section home-faq">
    <div class="faq-layout">
      <div class="faq-cardlet">
        <p class="eyebrow">FAQ</p>
        <h3>Quick answers.</h3>
        <p>Need the short version before playing?</p>
      </div>
      <div class="faq-list" data-faq-list>
        {faqItems.map(([question, answer]) => (
          <details>
            <summary>{question}</summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="home-cta">
    <div>
      <p class="eyebrow">Ready?</p>
      <h3>Open a level and start sorting.</h3>
    </div>
    <a class="primary-action" href="/play/"><span class="play-triangle"></span>Play Magic Sort</a>
  </section>

  <script is:inline>
    (() => {
      document.querySelectorAll("[data-faq-list]").forEach((list) => {
        list.querySelectorAll("details").forEach((item) => {
          item.addEventListener("toggle", () => {
            if (!item.open) return;
            list.querySelectorAll("details[open]").forEach((other) => {
              if (other !== item) other.open = false;
            });
          });
        });
      });
    })();
  </script>
</BaseLayout>
